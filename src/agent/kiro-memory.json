{
  "name": "kiro-memory",
  "description": "带持久记忆的默认开发助手，自动记录会话历史并在后续会话中注入相关上下文",
  "prompt": "file://__KIRO_MEMORY_DIR__/prompt.md",
  "tools": ["*"],
  "hooks": {
    "agentSpawn": [
      {
        "command": "__KIRO_MEMORY_DIR__/hooks/context.sh",
        "timeout_ms": 5000,
        "max_output_size": 10240
      }
    ],
    "userPromptSubmit": [
      {
        "command": "__KIRO_MEMORY_DIR__/hooks/prompt-save.sh",
        "timeout_ms": 3000
      }
    ],
    "postToolUse": [
      {
        "command": "__KIRO_MEMORY_DIR__/hooks/observation.sh",
        "timeout_ms": 3000
      }
    ],
    "stop": [
      {
        "command": "__KIRO_MEMORY_DIR__/hooks/summary.sh",
        "timeout_ms": 3000
      }
    ]
  },
  "mcpServers": {
    "kiro-memory": {
      "command": "bun",
      "args": ["run", "__KIRO_MEMORY_DIR__/src/server/mcp-server.ts"],
      "env": {
        "KIRO_MEMORY_DATA_DIR": "__KIRO_MEMORY_DIR__"
      }
    }
  }
}
