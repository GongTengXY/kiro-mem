{
  "name": "kiro-mem",
  "version": "0.2.0",
  "description": "Persistent cross-session memory system for Kiro CLI. Auto-captures tool calls, compresses via LLM, and injects historical context.",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GongTengXY/kiro-mem.git"
  },
  "keywords": [
    "kiro",
    "kiro-cli",
    "memory",
    "mcp",
    "ai",
    "context",
    "persistence",
    "sqlite",
    "llm"
  ],
  "bin": {
    "kiro-mem": "./scripts/setup.ts"
  },
  "files": [
    "src",
    "scripts",
    "index.ts",
    "tsconfig.json",
    "README.md"
  ],
  "scripts": {
    "worker": "bun run src/server/worker.ts",
    "mcp": "bun run src/server/mcp-server.ts",
    "setup": "bun run scripts/setup.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.14"
  }
}
